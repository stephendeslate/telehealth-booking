# Database
DATABASE_URL=postgresql://medconnect:medconnect@localhost:5432/medconnect

# Redis
REDIS_URL=redis://localhost:6379

# JWT (auto-generated in dev if not set)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Stripe (mock mode if not set)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio (mock mode if not set)
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Google OAuth (mock mode if not set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Calendar (stub if not set)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Resend (mock mode if not set)
RESEND_API_KEY=
FROM_EMAIL=noreply@medconnect.local

# Cloudflare R2 (mock mode if not set)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=medconnect-uploads
R2_PUBLIC_URL=http://localhost:3001/uploads

# Calendar token encryption (32-byte hex key for AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CALENDAR_TOKEN_ENCRYPTION_KEY=

# Sentry (disabled if not set)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_DSN=

# App
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
VIDEO_PROVIDER=mock
NODE_ENV=development
PORT=3001
